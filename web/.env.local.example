# Get this from Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# The URL of your deployed Vercel app (used for CORS on local runner)
# No trailing slash
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Local runner URL — don't change this unless you use a different port
NEXT_PUBLIC_LOCAL_RUNNER_URL=http://localhost:3737
